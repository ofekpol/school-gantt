# Supabase (D-02 — fill before running migrations or seed)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection for Drizzle migrations + seed (uses service role)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Test database (separate Supabase project recommended; falls back to skipping integration tests if unset)
TEST_DATABASE_URL=

# Resend for password reset email (AUTH-02)
RESEND_API_KEY=re_...

# Sender address for transactional emails (invites, password reset).
# Must use a verified domain in Resend. Falls back to a placeholder if unset.
RESEND_FROM_EMAIL="School Gantt <no-reply@yourdomain.com>"

# App URL for password reset redirect target
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ⚠️ TEST-ONLY BACKDOOR — DO NOT SET IN PRODUCTION ⚠️
# When set to "1", enables /api/v1/auth/login password-bypass for E2E tests.
# Any other value (or unset) returns 404 from that route.
# Setting this in prod = full auth bypass. Leave unset everywhere except local/CI.
TEST_LOGIN_ENABLED=
